# Server
NODE_ENV=development
PORT=4000

# Database (Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bizlens?schema=public"
# Direct connection for migrations (bypasses connection pooler). Optional for local dev.
# DIRECT_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bizlens?schema=public"
# SSL: enabled by default for cloud providers. Set to "false" for local dev without SSL.
DATABASE_SSL=false

# Observability
# LOG_SLOW_QUERIES=true
# SLOW_QUERY_THRESHOLD_MS=500

# Auth
JWT_SECRET="replace-with-a-long-random-string-please"
JWT_EXPIRES_IN="7d"
COOKIE_DOMAIN=""
COOKIE_SECURE=false

# CORS - frontend origins (comma-separated)
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"
