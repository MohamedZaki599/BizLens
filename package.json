{
  "name": "bizlens",
  "version": "0.1.0",
  "private": true,
  "description": "BizLens - Financial command center for small businesses, freelancers, and service providers.",
  "workspaces": [
    "packages/*",
    "client",
    "server",
    "marketing"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace=server",
    "dev:client": "npm run dev --workspace=client",
    "dev:marketing": "npm run dev --workspace=marketing",
    "build:server": "npm run build --workspace=@bizlens/database && npm run build --workspace=server",
    "build:client": "npm run build --workspace=client",
    "build:marketing": "npm run build --workspace=marketing",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "db:generate": "npm run prisma:generate --workspace=@bizlens/database",
    "db:validate": "npm run prisma:validate --workspace=@bizlens/database",
    "db:migrate:dev": "npm run prisma:migrate:dev --workspace=@bizlens/database",
    "db:migrate:deploy": "npm run prisma:migrate:deploy --workspace=@bizlens/database"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.3.3"
  }
}
